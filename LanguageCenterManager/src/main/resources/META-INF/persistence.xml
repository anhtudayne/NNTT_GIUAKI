<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="LanguageCenterPU" transaction-type="RESOURCE_LOCAL">
        <!-- Khai báo provider của Hibernate -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <properties>
            <!-- Thông tin kết nối MySQL -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/language_center?createDatabaseIfNotExist=true&amp;useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/> <!-- Thay bằng tài khoản của bạn -->
            <property name="jakarta.persistence.jdbc.password" value="123456"/> <!-- Thay bằng mật khẩu của bạn -->

            <!-- Các thiết lập của Hibernate -->
            <!-- Tự động tạo bảng/cập nhật cấu trúc bảng (chỉ nên dùng update khi phát triển) -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            
            <!-- In câu lệnh SQL ra console để dễ debug -->
            <property name="hibernate.show_sql" value="true"/>
            
            <!-- Định dạng SQL cho dễ nhìn -->
            <property name="hibernate.format_sql" value="true"/>
            
            <!-- Dialect cho MySQL (8.0 trở lên) -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
        </properties>
    </persistence-unit>
</persistence>
